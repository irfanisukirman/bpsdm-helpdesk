APP_NAME="Helpdesk BPSDM Jabar"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Asia/Jakarta
APP_URL=http://localhost

APP_LOCALE=id
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=id_ID

APP_MAINTENANCE_DRIVER=file

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# --- Basis data ---
# Produksi: MySQL 8 / MariaDB 10.6+ (sesuai PRD). Contoh:
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=helpdesk_bpsdm
# DB_USERNAME=helpdesk
# DB_PASSWORD=secret
#
# Pengembangan lokal cepat: SQLite (tanpa server DB terpisah)
DB_CONNECTION=sqlite

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# Antrean surel: database (tidak memblokir permintaan pengguna)
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# --- Surel ---
# Produksi: SMTP resmi BPSDM. Untuk pengembangan gunakan 'log'.
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="helpdesk@bpsdm.jabarprov.go.id"
MAIL_FROM_NAME="${APP_NAME}"

# --- Konfigurasi Helpdesk ---
# Alamat pengelola tunggal untuk seluruh notifikasi tahap awal (PRD Bagian 2.2)
HELPDESK_MANAGER_EMAIL="pengelola.helpdesk@bpsdm.jabarprov.go.id"
# Penerima eskalasi (dapat diarahkan ke alamat pengelola yang sama pada tahap awal)
HELPDESK_COORDINATOR_EMAIL="${HELPDESK_MANAGER_EMAIL}"
HELPDESK_KABID_EMAIL="${HELPDESK_MANAGER_EMAIL}"
HELPDESK_SUPERADMIN_EMAIL="${HELPDESK_MANAGER_EMAIL}"
# Batas buka kembali tiket (hari kerja) — PRD Bagian 5.10
HELPDESK_REOPEN_WINDOW_DAYS=3

# Tautan LMS (Model B1 — sekadar tautan pengarah)
LMS_URL="https://jabarcorputalent.jabarprov.go.id/"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
